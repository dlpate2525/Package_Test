    DISTINCTCOUNT( AYX_PROD_APPS_COLLECTION_SUMMARY[AS_APPLICATION_ID] ),
    AYX_PROD_APPS_COLLECTION_SUMMARY[Is_Orphaned_Flag] = 1
)

Workflow Duplicates_Base =
