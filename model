### 6.3 Job Runs Measures (formerly Queue)

All measure names retained as `Queue ...` for backward compatibility with existing semantic model references.

#### L2 Base

```dax
Queue Total Runs CM_Base =
CALCULATE(
    COUNTROWS( QUEUE_WORKER_APPLICATION ),
    QUEUE_WORKER_APPLICATION[AYX_RUN_DT] >= [_CM Start],
    QUEUE_WORKER_APPLICATION[AYX_RUN_DT] <= [_CM End]
)

Queue Scheduled Runs CM_Base =
CALCULATE( [Queue Total Runs CM_Base], QUEUE_WORKER_APPLICATION[Trigger_Type] = "Scheduled" )

Queue Manual Runs CM_Base =
[Queue Total Runs CM_Base] - [Queue Scheduled Runs CM_Base]

Queue Avg Runtime CM_Base =
CALCULATE(
    AVERAGE( QUEUE_WORKER_APPLICATION[FUL_RUN_TIME] ),
    QUEUE_WORKER_APPLICATION[AYX_RUN_DT] >= [_CM Start],
    QUEUE_WORKER_APPLICATION[AYX_RUN_DT] <= [_CM End]
)

Queue Avg Runtime PM_Base =
CALCULATE(
    AVERAGE( QUEUE_WORKER_APPLICATION[FUL_RUN_TIME] ),
    QUEUE_WORKER_APPLICATION[AYX_RUN_DT] >= [_PM Start],
    QUEUE_WORKER_APPLICATION[AYX_RUN_DT] <= [_PM End]
)

Queue P95 Runtime CM_Base =
CALCULATE(
    PERCENTILEX.INC( QUEUE_WORKER_APPLICATION, QUEUE_WORKER_APPLICATION[FUL_RUN_TIME], 0.95 ),
    QUEUE_WORKER_APPLICATION[AYX_RUN_DT] >= [_CM Start],
    QUEUE_WORKER_APPLICATION[AYX_RUN_DT] <= [_CM End]
)

Queue Failed Runs CM_Base =
CALCULATE(
    COUNTROWS( QUEUE_WORKER_APPLICATION ),
    QUEUE_WORKER_APPLICATION[Is_Error] = 1,
    QUEUE_WORKER_APPLICATION[AYX_RUN_DT] >= [_CM Start],
    QUEUE_WORKER_APPLICATION[AYX_RUN_DT] <= [_CM End]
)

Queue Error Rate CM_Base =
DIVIDE( [Queue Failed Runs CM_Base], [Queue Total Runs CM_Base], 0 )

Queue Error Rate PM_Base =
DIVIDE(
    CALCULATE(
        COUNTROWS( QUEUE_WORKER_APPLICATION ),
        QUEUE_WORKER_APPLICATION[Is_Error] = 1,
        QUEUE_WORKER_APPLICATION[AYX_RUN_DT] >= [_PM Start],
        QUEUE_WORKER_APPLICATION[AYX_RUN_DT] <= [_PM End]
    ),
