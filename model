    MAX( QUEUE_WORKER_APPLICATION[FUL_RUN_TIME] ),
    QUEUE_WORKER_APPLICATION[AYX_RUN_DT] >= [_CM Start],
    QUEUE_WORKER_APPLICATION[AYX_RUN_DT] <= [_CM End]
)

Workflow Min Runtime CM_Base =
CALCULATE(
    MIN( QUEUE_WORKER_APPLICATION[FUL_RUN_TIME] ),
    QUEUE_WORKER_APPLICATION[AYX_RUN_DT] >= [_CM Start],
    QUEUE_WORKER_APPLICATION[AYX_RUN_DT] <= [_CM End]
)

Workflow Total Compute Hours CM_Base =
DIVIDE(
    CALCULATE(
        SUM( QUEUE_WORKER_APPLICATION[FUL_RUN_TIME] ),
        QUEUE_WORKER_APPLICATION[AYX_RUN_DT] >= [_CM Start],
        QUEUE_WORKER_APPLICATION[AYX_RUN_DT] <= [_CM End]
    ),
    3600
)

Workflow Last Run Date_Base =
CALCULATE(
    MAX( QUEUE_WORKER_APPLICATION[AYX_RUN_DT] ),
    QUEUE_WORKER_APPLICATION[AYX_RUN_DT] >= [_CM Start],
    QUEUE_WORKER_APPLICATION[AYX_RUN_DT] <= [_CM End]
)
