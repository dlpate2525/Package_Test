    EXCEPT(
        SELECTCOLUMNS( COLLECTION_USER_INVENTORY, "C", COLLECTION_USER_INVENTORY[COLLECTION_NAME] ),
        SELECTCOLUMNS( COLLECTION_GROUPS_INVENTORY, "C", COLLECTION_GROUPS_INVENTORY[COLLECTION_NAME] )
    )
RETURN COUNTROWS( DirectOnly )

Workflow Collection Health Pct_Base =
DIVIDE(
    DISTINCTCOUNT( COLLECTION_GROUPS_INVENTORY[COLLECTION_NAME] ),
    DISTINCTCOUNT( Collections_LineOfBusiness_Mapping[COLLECTION_NAME] ),
