### 3.1 Load Dim_Date

Rebuild the date dimension from scratch using a recursive CTE across a 10-year span. Adjust `@Date_Start` / `@Date_End` to fit reporting needs.

```sql
DECLARE @Date_Start DATE = '2020-01-01';
DECLARE @Date_End   DATE = '2029-12-31';

;WITH Calendar AS
(
    SELECT @Date_Start AS Calendar_Date
    UNION ALL
    SELECT DATEADD(DAY, 1, Calendar_Date)
    FROM Calendar
    WHERE Calendar_Date < @Date_End
)
INSERT INTO dbo.Dim_Date
(
    Date_Id, Calendar_Date, Day_Of_Week_Number, Day_Of_Week_Name, Day_Of_Month,
    Day_Of_Year, Week_Of_Year, Month_Number, Month_Name, Month_Short_Name,
    Quarter_Number, Quarter_Name, Calendar_Year, Year_Month, Year_Quarter,
    Weekday_Flag, Month_Start_Flag, Month_End_Flag
)
SELECT
    CONVERT(INT, CONVERT(CHAR(8), Calendar_Date, 112))                   AS Date_Id,
    Calendar_Date                                                        AS Calendar_Date,
    DATEPART(WEEKDAY, Calendar_Date)                                     AS Day_Of_Week_Number,
    DATENAME(WEEKDAY, Calendar_Date)                                     AS Day_Of_Week_Name,
    DAY(Calendar_Date)                                                   AS Day_Of_Month,
    DATEPART(DAYOFYEAR, Calendar_Date)                                   AS Day_Of_Year,
    DATEPART(ISO_WEEK,  Calendar_Date)                                   AS Week_Of_Year,
    MONTH(Calendar_Date)                                                 AS Month_Number,
    DATENAME(MONTH, Calendar_Date)                                       AS Month_Name,
    LEFT(DATENAME(MONTH, Calendar_Date), 3)                              AS Month_Short_Name,
    DATEPART(QUARTER, Calendar_Date)                                     AS Quarter_Number,
    'Q' + CAST(DATEPART(QUARTER, Calendar_Date) AS CHAR(1))              AS Quarter_Name,
    YEAR(Calendar_Date)                                                  AS Calendar_Year,
    FORMAT(Calendar_Date, 'yyyy-MM')                                     AS Year_Month,
    CAST(YEAR(Calendar_Date) AS CHAR(4)) + '-Q'
        + CAST(DATEPART(QUARTER, Calendar_Date) AS CHAR(1))              AS Year_Quarter,
    CASE WHEN DATEPART(WEEKDAY, Calendar_Date) BETWEEN 2 AND 6 THEN 1 ELSE 0 END AS Weekday_Flag,
    CASE WHEN DAY(Calendar_Date) = 1 THEN 1 ELSE 0 END                   AS Month_Start_Flag,
    CASE WHEN Calendar_Date = EOMONTH(Calendar_Date) THEN 1 ELSE 0 END   AS Month_End_Flag
FROM Calendar
OPTION (MAXRECURSION 0);
GO
```

### 3.2 Load Dim_Employee

Source of truth for employees is `Direct_Report.USERS_EMPLOYEE_LOB`, which carries the most complete org hierarchy. Deduplicated on ELID. Change Champion flag is LEFT JOIN-merged from `RawP.ChangeChampion` (email match). Termination data comes from `RawP.Employee_Terms`. Login aggregates derive from `SESSIONS_USERS_LOB`.

```sql
INSERT INTO dbo.Dim_Employee
(
    Elid, Email_Primary_Work, Display_Name, First_Name, Last_Name,
    Level_03_Name, Level_04_Name, Level_05_Name, Level_06_Name,
    Cost_Center, Cost_Center_Name, International_Domestic_Flag,
    City, State, Country,
    Change_Champion_Flag, Champion_Effective_Date,
    Terminated_Flag, Termination_Date,
    Gallery_User_Id, Gallery_Role, Server_Account_Flag, Desktop_License_Flag,
    Last_Login_Date, Login_Count_Last_90_Days
)
SELECT
    u.ELID                                            AS Elid,
    u.EMAIL_PRIMARY_WORK                              AS Email_Primary_Work,
    u.DISPLAY_NAME                                    AS Display_Name,           /* VERIFY */
    u.FIRST_NAME                                      AS First_Name,             /* VERIFY */
    u.LAST_NAME                                       AS Last_Name,              /* VERIFY */
    u.LEVEL_03_FROM_TOP                               AS Level_03_Name,
    u.LEVEL_04_FROM_TOP                               AS Level_04_Name,
    u.LEVEL_05_FROM_TOP                               AS Level_05_Name,
    u.LEVEL_06_FROM_TOP                               AS Level_06_Name,
    u.COST_CENTER                                     AS Cost_Center,            /* VERIFY */
    u.COST_CENTER_NAME                                AS Cost_Center_Name,       /* VERIFY */
    u.INTERNATIONAL_DOMESTIC_FLAG                     AS International_Domestic_Flag,
    u.PRIMARY_WORK_ADDRESS_CITY                       AS City,
    u.PRIMARY_WORK_ADDRESS_STATE_PROVINCE             AS State,
    u.PRIMARY_WORK_ADDRESS_COUNTRY                    AS Country,
    CASE WHEN cc.CLEAN_EMAIL IS NOT NULL THEN 1 ELSE 0 END AS Change_Champion_Flag,
    cc.CHAMPION_EFFECTIVE_DATE                        AS Champion_Effective_Date,  /* VERIFY */
    CASE WHEN et.EMAIL_PRIMARY_WORK IS NOT NULL THEN 1 ELSE 0 END AS Terminated_Flag,
    et.TERMINATION_DATE                               AS Termination_Date,         /* VERIFY */
    ag.GALLERY_USER_ID                                AS Gallery_User_Id,          /* VERIFY */
    ag.GALLERY_ROLE                                   AS Gallery_Role,             /* VERIFY */
    CASE WHEN ag.GALLERY_USER_ID IS NOT NULL THEN 1 ELSE 0 END AS Server_Account_Flag,
    ISNULL(u.DESKTOP_LICENSE_FLAG, 0)                 AS Desktop_License_Flag,     /* VERIFY */
    s.LAST_LOGIN_DATE                                 AS Last_Login_Date,
    ISNULL(s.LOGIN_COUNT_LAST_90_DAYS, 0)             AS Login_Count_Last_90_Days
FROM
(
    SELECT
        u0.*,
        ROW_NUMBER() OVER (PARTITION BY u0.ELID ORDER BY u0.EMAIL_PRIMARY_WORK) AS Rn
    FROM CRDP_DEV_MIRROR.Direct_Report.USERS_EMPLOYEE_LOB AS u0
    WHERE u0.ELID IS NOT NULL
) AS u

LEFT JOIN CRDP_DEV_MIRROR.RawP.ChangeChampion AS cc
    ON LOWER(cc.CLEAN_EMAIL) = LOWER(u.EMAIL_PRIMARY_WORK)

LEFT JOIN CRDP_DEV_MIRROR.RawP.Employee_Terms AS et
    ON LOWER(et.EMAIL_PRIMARY_WORK) = LOWER(u.EMAIL_PRIMARY_WORK)

LEFT JOIN
(
    SELECT
        LOWER(EMAIL)        AS EMAIL_LOWER,
        _id                 AS GALLERY_USER_ID,    /* VERIFY source col */
        Role                AS GALLERY_ROLE        /* VERIFY source col */
    FROM CRDP_DEV_MIRROR.RawP.AlteryxGallery_users
) AS ag
    ON ag.EMAIL_LOWER = LOWER(u.EMAIL_PRIMARY_WORK)

LEFT JOIN
(
    SELECT
        LOWER(CLEAN_EMAIL)                                     AS EMAIL_LOWER,
        MAX(CAST(SESSION_DATE AS DATE))                        AS LAST_LOGIN_DATE,   /* VERIFY */
        SUM(CASE WHEN SESSION_DATE >= DATEADD(DAY, -90, GETDATE()) THEN 1 ELSE 0 END) AS LOGIN_COUNT_LAST_90_DAYS
    FROM CRDP_DEV_MIRROR.Direct_Report.SESSIONS_USERS_LOB
    GROUP BY LOWER(CLEAN_EMAIL)
) AS s
    ON s.EMAIL_LOWER = LOWER(u.EMAIL_PRIMARY_WORK)

WHERE u.Rn = 1;
GO
```

