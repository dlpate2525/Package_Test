    grp.User_Group_Id,
    'Group',
    dg.DATE_ADDED                                                              /* VERIFY */
FROM CRDP_DEV_MIRROR.Direct_Report.USERGROUP_DATACONNECTION_INVENTORY AS dg
INNER JOIN dbo.Dim_Data_Connection AS dc  ON dc.Gallery_Connection_Id  = dg.CONNECTION_ID
INNER JOIN dbo.Dim_User_Group      AS grp ON grp.Gallery_User_Group_Id = dg.USERGROUP_ID
WHERE dg.CONNECTION_ID IS NOT NULL AND dg.USERGROUP_ID IS NOT NULL;
GO
```

### 3.10 Load Fact_Job_Execution

Primary source is `QUEUE_WORKER_APPLICATION` (atomic job grain). Employee resolved via `QUEUE_USERS_LOB` email lookup, which shares `JOB_ID`. Breach flags taken directly from source columns. `Employee_Id` is LEFT JOIN so orphaned-risk jobs (terminated users) still load with NULL employee if their email no longer matches a `Dim_Employee` row.

```sql
INSERT INTO dbo.Fact_Job_Execution
(
    Job_Id, Application_Id, Employee_Id, Schedule_Id,
    Queue_Date_Id, Completion_Date_Id,
    Queue_Created_Dt, Engine_Start_Dt, Completion_Dt,
    Queue_Wait_Seconds, Engine_Runtime_Seconds, Total_Duration_Seconds,
    Execution_Status, Result_Code, Error_Flag, Warning_Flag, Error_Message,
    Client_Type, Worker_Tag, Server_Id, Priority, Amp_Flag, Anonymous_Flag, Job_Name,
    Breach_Half_Hour_Flag, Breach_Hour_Flag, Breach_Normal_Flag, Peak_Window_Flag,
    Result_File_Size_Bytes
)
SELECT
    q.JOB_ID                                                                 AS Job_Id,
    app.Application_Id                                                       AS Application_Id,
    emp.Employee_Id                                                          AS Employee_Id,
    sch.Schedule_Id                                                          AS Schedule_Id,
    CONVERT(INT, CONVERT(CHAR(8), q.START_DATE, 112))                        AS Queue_Date_Id,
    CASE WHEN q.END_DATE IS NOT NULL
         THEN CONVERT(INT, CONVERT(CHAR(8), q.END_DATE, 112))
         ELSE NULL END                                                       AS Completion_Date_Id,
    q.START_DT                                                               AS Queue_Created_Dt,
    NULL                                                                     AS Engine_Start_Dt,
    q.END_DT                                                                 AS Completion_Dt,
    q.QUEUE_TIME                                                             AS Queue_Wait_Seconds,
    q.FUL_RUN_TIME                                                           AS Engine_Runtime_Seconds,
    CASE WHEN q.QUEUE_TIME IS NOT NULL AND q.FUL_RUN_TIME IS NOT NULL
         THEN q.QUEUE_TIME + q.FUL_RUN_TIME
         ELSE NULL END                                                       AS Total_Duration_Seconds,
    q.STATUS                                                                 AS Execution_Status,
    CASE q.STATUS
         WHEN 'Complete' THEN
             CASE WHEN q.EXEC = 0 THEN 0
                  WHEN q.EXEC = 1 THEN 1
                  WHEN q.EXEC = 2 THEN 2
                  ELSE NULL END
         ELSE NULL END                                                       AS Result_Code,
    CASE WHEN q.EXEC = 2 THEN 1 ELSE 0 END                                   AS Error_Flag,
    CASE WHEN q.EXEC = 1 THEN 1 ELSE 0 END                                   AS Warning_Flag,
    q.ERROR_MESSAGE                                                          AS Error_Message,        /* VERIFY */
    q.CLIENT_TYPE                                                            AS Client_Type,          /* VERIFY */
    q.WORKER_TAG                                                             AS Worker_Tag,           /* VERIFY */
    q.SERVER_ID                                                              AS Server_Id,
    q.PRIORITY                                                               AS Priority,             /* VERIFY */
    ISNULL(q.IS_AMP, 0)                                                      AS Amp_Flag,             /* VERIFY */
    ISNULL(q.IS_ANONYMOUS, 0)                                                AS Anonymous_Flag,       /* VERIFY */
    q.JOB_NAME                                                               AS Job_Name,             /* VERIFY */
    ISNULL(q.BREACH_HALF_HOUR, 0)                                            AS Breach_Half_Hour_Flag,
    ISNULL(q.BREACH_HOUR, 0)                                                 AS Breach_Hour_Flag,
    ISNULL(q.BREACH_NORMAL_TIME, 0)                                          AS Breach_Normal_Flag,
    ISNULL(q.PEAK, 0)                                                        AS Peak_Window_Flag,
    q.RESULT_FILE_SIZE                                                       AS Result_File_Size_Bytes /* VERIFY */
FROM CRDP_DEV_MIRROR.Direct_Report.QUEUE_WORKER_APPLICATION AS q

INNER JOIN dbo.Dim_Application AS app
    ON app.Service_Id = q.AS_APPLICATION_ID

LEFT JOIN CRDP_DEV_MIRROR.Direct_Report.QUEUE_USERS_LOB AS qu
    ON qu.JOB_ID = q.JOB_ID

LEFT JOIN dbo.Dim_Employee AS emp
    ON LOWER(emp.Email_Primary_Work) = LOWER(qu.EMAIL_PRIMARY_WORK)

LEFT JOIN dbo.Dim_Schedule AS sch
    ON sch.Gallery_Schedule_Id = q.SCHEDULE_ID                               /* VERIFY */

WHERE q.JOB_ID IS NOT NULL;
GO
```

